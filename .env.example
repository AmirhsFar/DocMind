ENVIRONMENT=development

# These hostnames (postgres, redis) match the service names in docker-compose.yml
DATABASE_URL=postgresql+asyncpg://docmind:docmind@postgres:5432/docmind
REDIS_URL=redis://redis:6379/0

SECRET_KEY=change-me-in-production

# Filled in during Phase 4 (LLM integration). Leave blank for now.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# MinIO Object Storage
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=docmind-files
MINIO_SECURE=False
